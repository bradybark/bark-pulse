# All current layers (earthquakes, weather alerts, flights) work with NO keys.
# The variables below are optional enhancements / future layers.

# OpenSky flights work anonymously but are rate-limited. Set these to lift the
# limit (Basic auth). Register at https://opensky-network.org/
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# NASA FIRMS active-fire detections (future layer) — free MAP_KEY at
# https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=
