# All current layers (earthquakes, weather alerts, flights) work with NO keys.
# The variables below are optional enhancements / future layers.

# OpenSky flights work anonymously but are heavily rate-limited (frequent 429s).
# Create an API client at https://opensky-network.org/ (My OpenSky → API Clients)
# and paste the OAuth2 client credentials here to lift the limit.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# NASA FIRMS active-fire detections (Wildfires layer) — REQUIRED for that layer.
# Get a free MAP_KEY in ~30s at https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=
